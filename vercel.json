{
  "rewrites": [
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    }
  ],
  "redirects": [
    { "source": "/about-us", "destination": "/", "statusCode": 301 },
    { "source": "/work-gallery", "destination": "/", "statusCode": 301 },
    { "source": "/adelaide-course-reviews", "destination": "/", "statusCode": 301 },
    { "source": "/brand-ambassador-program", "destination": "/", "statusCode": 301 },
    { "source": "/review-gallery", "destination": "/", "statusCode": 301 },
    { "source": "/eyelash-extensions-consent-form", "destination": "/", "statusCode": 301 },
    { "source": "/eyelash-extensions-consent-agreement-form", "destination": "/", "statusCode": 301 },
    {
      "has": [
        {
          "type": "host",
          "value": "lashcourse.lashmama.com.au"
        }
      ],
      "source": "/(.*)",
      "destination": "https://www.lashmama.com.au/",
      "statusCode": 301
    }
  ]
}